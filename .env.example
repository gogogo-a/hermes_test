# Copy to project root `.env`. Do NOT commit `.env`.

# ===================== 智谱 BigModel =====================
ZHIPU_API_KEY=

# Nous Hermes-Agent (router brain) maps ZHIPU_API_KEY → GLM/ZAI; OpenAI-compat base:
BIGMODEL_BASE_URL=https://open.bigmodel.cn/api/paas/v4
HERMES_NOUS_MODEL=glm-4-flash
# Router runs AIAgent with no toolsets; keep iterations low for latency
HERMES_NOUS_MAX_ITERATIONS=12
# Dev/CI only: skip GLM and return fixed subtasks (no Nous LLM call).
# HERMES_ROUTER_MOCK=0

# ===================== Kafka (host dev: use external port from compose) =====================
KAFKA_BOOTSTRAP=localhost:19092

# Topics (override if renamed)
TOPIC_TASKS_INBOUND=hermes.tasks.inbound
TOPIC_TASKS_DISPATCH=hermes.tasks.dispatch
TOPIC_TASKS_RESULTS=hermes.tasks.results
TOPIC_TASKS_DLQ=hermes.tasks.dlq

# ===================== Gateway (Go) =====================
GATEWAY_ADDR=:8080
MAX_HOPS=5
# Relative paths work when resolving from `./gateway`; main also probes `../contracts/…`
TASK_SCHEMA_PATH=contracts/task-envelope.schema.json

# ===================== RAG =====================
QDRANT_URL=http://localhost:6333
RAG_COLLECTION=hermes_docs
RAG_EMBED_PROVIDER=fastembed
RAG_URL=http://127.0.0.1:8090
RAG_HTTP_PORT=8090

# ===================== Redis (optional: idempotency / future) =====================
REDIS_URL=redis://localhost:6379
